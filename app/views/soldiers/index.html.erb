<% content_for :headTitle do %>
  Soldats
<% end %>

<% content_for :contentHeader do %>
  <h2>Soldats &nbsp; <%= link_to 'Nouveau soldat', new_soldier_path, :class => 'btn btn-success' %></h2>

  <ol class="breadcrumb">
    <li><a href="#">Accueil</a></li>
    <li><%= link_to 'Soldats', soldiers_path %></li>
    <li class="active">index</li>
  </ol>
<% end %>

<div class="box">
  <table class="table">
    <thead>
      <tr>
        <th>Nom</th>
        <th>Prénom(s)</th>
        <th>Date de naissance</th>
        <th>Lieu de naissance</th>
        <th>Date de décès</th>
        <th>Lieu de décès</th>
        <th colspan="3">Actions</th>
      </tr>
    </thead>

    <tbody>
      <% @soldiers.each do |soldier| %>
        <tr>
          <td><%= soldier.lastname %></td>
          <td><%= soldier.firstname %></td>
          <td><%= l soldier.date_of_birth %></td>
          <td><%= soldier.place_of_birth %></td>
          <td><%= l soldier.date_of_death %></td>
          <td><%= soldier.place_of_death %></td>
          <td><%= link_to 'Voir', soldier, { class: 'btn btn-primary btn-sm'} %></td>
          <td><%= link_to 'Modifier', edit_soldier_path(soldier), { class: 'btn btn-warning btn-sm'} %></td>
          <td><%= link_to 'Supprimer', soldier, :class => 'btn btn-danger btn-sm', method: :delete, data: { confirm: 'Êtes-vous sûr ?'} %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
