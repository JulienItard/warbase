<%= form_for([soldier, promotion]) do |f| %>
  <% if promotion.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(promotion.errors.count, "error") %> prohibited this promotion from being saved:</h2>

      <ul>
      <% promotion.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= f.label :rank_id, "Grade :" %>
    <%= f.collection_select :rank_id, Rank.all, :id, :name %>
  </div>

  <div class="field">
    <%= f.label :date, "Date :" %>
    <%= f.date_select :date, start_year: 1900, end_year: 1950 %>
  </div>

  <div class="field">
    <%= f.label :temporary, "Temporaire ?" %>
    <%= f.check_box :temporary %>
  </div>

  <div class="actions">
    <%= f.submit "Sauvegarder" %>
  </div>
<% end %>
