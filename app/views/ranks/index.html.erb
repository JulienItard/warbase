<p id="notice"><%= notice %></p>

<h1>Grades</h1>

<table>
  <thead>
    <tr>
      <th>Nom</th>
      <th colspan="3">Actions</th>
    </tr>
  </thead>

  <tbody>
    <% @ranks.each do |rank| %>
      <tr>
        <td><%= rank.name %></td>
        <td><%= link_to 'Voir', rank %></td>
        <td><%= link_to 'Modifier', edit_rank_path(rank) %></td>
        <td><%= link_to 'Supprimer', rank, method: :delete, data: { confirm: 'Êtes-vous sûr ?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'Nouveau grade', new_rank_path %>
